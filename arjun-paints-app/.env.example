APP_NAME="Arjun Paints"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Supabase = PostgreSQL. Copy host, password, and DB name from Supabase → Project Settings → Database.
# For quick local runs without Supabase, you can use: DB_CONNECTION=sqlite (empty DB_DATABASE).
DB_CONNECTION=pgsql
DB_HOST=db.YOUR_PROJECT_REF.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=

# Supabase cloud requires SSL — use "require" (see config/database.php pgsql.sslmode).
DB_SSLMODE=require

# --- Render / Railway + Supabase: "Network is unreachable" on db.*.supabase.co ---
# Direct DB host is often IPv6-only; many hosts only route IPv4 → use Supabase *pooler* (IPv4).
# Dashboard: Project Settings → Database → Connection string → Tab "Connection pooling" → Mode "Session".
# Set these from that screen (host/user differ from direct):
#   DB_HOST=aws-0-REGION.pooler.supabase.com
#   DB_PORT=5432
#   DB_USERNAME=postgres.YOUR_PROJECT_REF
#   DB_PASSWORD=(same database password)
#   DB_SSLMODE=require
# Or paste the full URI into DATABASE_URL (Render Postgres addon also sets DATABASE_URL).
# DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-0-....pooler.supabase.com:5432/postgres?sslmode=require

# --- Supabase API keys (optional) ---
# Laravel + Eloquent uses only DB_* above — anon/service role are NOT required for that.
# Use these only if you call Supabase REST / JS client / Storage from your app:
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=eyJhbG...   (safe for browser; respect Row Level Security)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbG...   (server-side only — bypasses RLS; never expose to frontend or commit)

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
